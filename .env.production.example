# ============================================================
# Production environment — set these in your hosting platform
# (e.g. Vercel environment variables, GitHub Secrets, etc.)
# ============================================================
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SITE_URL=https://toolshare.example

# Supabase (production project)
NEXT_PUBLIC_SUPABASE_URL=https://your-prod-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-prod-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# Email (Resend)
RESEND_API_KEY=re_live_your_api_key
EMAIL_FROM=noreply@tool-share.eu

# Supabase Auth Send Email Hook (standard-webhooks secret)
SEND_EMAIL_HOOK_SECRET=whsec_your-webhook-secret-here

# Sentry (production project)
SENTRY_DSN=https://your-prod-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-prod-dsn@sentry.io/project-id

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cron job authentication
CRON_SECRET=your-cron-secret-here
