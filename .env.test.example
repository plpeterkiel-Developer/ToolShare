# ============================================================
# BDD test runner — copy to .env.test and fill in values
# ============================================================
TEST_BASE_URL=http://localhost:3000
HEADLESS=true

# Use local Supabase (run: supabase start)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ============================================================
# Deployed test/staging environment — set these when deploying
# to the test environment (separate Supabase project, etc.)
# ============================================================
# NEXT_PUBLIC_APP_ENV=test
# NEXT_PUBLIC_SITE_URL=https://test.toolshare.example
#
# NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
#
# RESEND_API_KEY=re_test_your_api_key
# EMAIL_FROM=noreply@test.toolshare.example
#
# SEND_EMAIL_HOOK_SECRET=whsec_your-webhook-secret-here
#
# SENTRY_DSN=https://your-test-dsn@sentry.io/project-id
# NEXT_PUBLIC_SENTRY_DSN=https://your-test-dsn@sentry.io/project-id
