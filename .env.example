# Environment — 'development' | 'test' | 'production'
NEXT_PUBLIC_APP_ENV=development

# App URL (used for email links and OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# Supabase Auth Send Email Hook (standard-webhooks secret)
SEND_EMAIL_HOOK_SECRET=whsec_your-webhook-secret-here

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Rate limiting (Upstash Redis) — optional for local dev
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cron job authentication
CRON_SECRET=your-cron-secret-here
